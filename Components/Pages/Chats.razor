@* This code is designed to run on the Blazor Web app(Interactive server)*@

@page "/"

@inject LlmChatServices ChatService
@inject IJSRuntime JS
@inject DocumentService DocumentService
@inject VectorSearchService VectorSearchService
@inject EmbeddingService EmbeddingService   
@inject UserDocumentService UserDocumentService

<PageTitle>AI Chatbot</PageTitle>
<p>Chatbot to answer questions</p>
<p>to give information about the changes</p>
<p>Request pull requests</p>
<div class="chat-container">

	<div class="message-list">
		@foreach (var msg in messages)
		{
            <div class="message @(msg.Role == "user" ? "user" : "assistant")">
                <div class="bubble">
                    <p>@msg.Content</p>
                </div>
            </div>
		}
		@if (isTyping)
		{
            <div class="message assistant">
                <div class="bubble typing">Loading...</div>
            </div>
		}
	</div>

    <div class="input-area">
        <input @bind="userInput" @bind:event="oninput" @onkeyup="HandleKeyUp"
               placeholder="メッセージを入力..." class="form-control" />
        <button @onclick="SendMessage" disabled="@isTyping" class="btn btn-primary">送信</button>
    </div>
</div>


<style>
    .chat-container {
        display: flex;
        flex-direction: column;
        height: 100vh;
    }

    .message-list {
        flex: 1;
        overflow-y: auto;
        padding: 10px;
    }

    .message {
        display: flex;
        margin: 8px 0;
    }

    .message.user {
        justify-content: flex-end;
    }

    .message.assistant {
        justify-content: flex-start;
    }

    .bubble {
        max-width: 70%;
        padding: 10px 14px;
        border-radius: 16px;
        font-size: 14px;
    }

    .message.user .bubble {
        background-color: #007bff;
        color: white;
        border-bottom-right-radius: 4px;
    }

    .message.assistant .bubble {
        background-color: #e5e5ea;
        color: black;
        border-bottom-left-radius: 4px;
    }

    .typing {
        font-style: italic;
        opacity: 0.7;
    }

    .input-area {
        display: flex;
        gap: 10px;
        padding: 10px;
        border-top: 1px solid #ccc;
        background: white;
    }

</style>

@* (UI部分は以前と同じ) *@
@code {
    private List<ChatMessage> messages = new();
    private string userInput = "";
    private bool isTyping = false;

    // 1. Add user's question to the list 
    // 2. Retrieve relevant documentation from RAG
    // 3. Request to LM Studio
    // 4. Display responses sequentially(Streaming)
    private async Task SendMessage()
    {
        if (string.IsNullOrWhiteSpace(userInput)) return;

        var userMsg = new ChatMessage { Role = "user", Content = userInput };
        messages.Add(userMsg);
        //var currentInput = userInput;
        userInput = "";
        isTyping = true;

        // 空のアシスタントメッセージを先に追加しておく
        var assistantMsg = new ChatMessage { Role = "assistant", Content = "" };
        messages.Add(assistantMsg);

        // ストリーミング実行
        await ChatService.GetChatResponseStreamAsync(messages.SkipLast(1).ToList(), UserDocumentService.SelectedTopK, (chunk) =>
        {
            assistantMsg.Content += chunk; // 届いた文字を結合
            StateHasChanged(); // Blazorに再描画を指示
        });

        isTyping = false;
    }

    private async Task HandleKeyUp(KeyboardEventArgs e)
    {
        if (e.Key == "Enter") await SendMessage();
    }
    
}




